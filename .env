# ── Database Oracle ─────────────────────────────────────────
DB_USER=SYSTEM
DB_PASSWORD=UjangInam2521
DB_CONNECT_STRING=localhost:1521/XE

# ── Server ──────────────────────────────────────────────────
PORT=3007

# ── CORS (URL frontend yang diizinkan) ──────────────────────
# Saat lokal, bisa pakai * atau http://localhost
# Saat sudah deploy online, ganti dengan URL frontend kamu
# Contoh: FRONTEND_URL=https://harlys-hotel.vercel.app
FRONTEND_URL=http://localhost:3000
