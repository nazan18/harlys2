# ============================================================
#  .env.example — Template konfigurasi environment
#  File ini AMAN untuk di-upload ke GitHub (tidak ada password)
#  
#  CARA PAKAI:
#  1. Copy file ini: cp .env.example .env
#  2. Isi nilai yang sesuai di file .env
#  3. Jangan pernah commit file .env ke GitHub!
# ============================================================

# ── Database Oracle ─────────────────────────────────────────
DB_USER=SYSTEM
DB_PASSWORD=isi_password_oracle_kamu
DB_CONNECT_STRING=localhost:1521/XE

# ── Server ──────────────────────────────────────────────────
PORT=3007

# ── CORS ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
